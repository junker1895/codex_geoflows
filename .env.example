APP_ENV=local
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/geoflows
FORECAST_DEFAULT_PROVIDER=geoglows
FORECAST_ENABLED_PROVIDERS=geoglows
GEOGLOWS_ENABLED=true
GEOGLOWS_SOURCE_TYPE=geoglows_api
GEOGLOWS_DEFAULT_RUN_SELECTOR=latest
GEOGLOWS_REQUEST_TIMEOUT_SECONDS=30
GEOGLOWS_DATA_SOURCE=rest
FORECAST_SUMMARY_DEFAULT_LIMIT=200
