APP_ENV=local
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/geoflows
FORECAST_DEFAULT_PROVIDER=geoglows
FORECAST_ENABLED_PROVIDERS=geoglows
GEOGLOWS_ENABLED=true
GEOGLOWS_SOURCE_TYPE=geoglows_api
GEOGLOWS_DEFAULT_RUN_SELECTOR=latest
GEOGLOWS_REQUEST_TIMEOUT_SECONDS=30
GEOGLOWS_DATA_SOURCE=rest
FORECAST_SUMMARY_DEFAULT_LIMIT=200

# GloFAS provider (uncomment to enable)
# FORECAST_ENABLED_PROVIDERS=geoglows,glofas
# GLOFAS_ENABLED=true
# GLOFAS_CDS_URL=https://ewds.climate.copernicus.eu/api
# GLOFAS_CDS_KEY=<your-copernicus-cds-personal-access-token>
# GLOFAS_SYSTEM_VERSION=operational
# GLOFAS_BULK_STAGING_DIR=./data/glofas_raw
# GLOFAS_BULK_RAW_RETENTION_RUNS=2
# GLOFAS_GRID_RESOLUTION=0.05
# GLOFAS_FORECAST_MAX_LEADTIME_HOURS=720
